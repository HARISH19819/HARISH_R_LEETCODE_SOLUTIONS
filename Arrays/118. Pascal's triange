class Solution:
    def generate(self, numRows: int) -> List[List[int]]:
        pascal=[[1],[1,1]]
        if numRows==1:
            return [[1]]
        elif numRows==2:
            return [[1],[1,1]]
        else:
            for _ in range(numRows-2):
                temp=[]
                temp.append(1)
                for i in range(len(pascal[-1])-1):
                    temp.append(pascal[-1][i]+pascal[-1][i+1])
                temp.append(1)
                pascal.append(temp)
            
            return pascal
